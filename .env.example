# Tidal API (server-only)
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=

# session secret — must be at least 32 chars
# generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=

# OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google authorized redirect URI to add in Google Cloud Console:
#   ${OAUTH_REDIRECT_BASE}/api/auth/oauth/google/callback
OAUTH_REDIRECT_BASE=http://localhost:6967

# filesystem paths
PROJECTS_DIR=/mnt/PLIKI/Dokumenty HDD/PROJECTS
DATA_DIR=./data

# github (for contributions calendar on /about) — classic PAT with read:user scope
# server-only; never exposed to the browser
GITHUB_TOKEN=
GITHUB_USERNAME=

# openrouter — ai writing assistant (admin-only, used in the post editor)
# OPENROUTER_API is also accepted for backward compat
OPENROUTER_API_KEY=
# primary model (tried first)
OPENROUTER_DEFAULT_MODEL=
# fallback models — tried in order if previous returns 429 / 402 / 503
OPENROUTER_SECONDARY_MODEL=
OPENROUTER_BACKUP_MODEL=
# optional extra overflow list, comma-separated
OPENROUTER_FALLBACK_MODELS=
